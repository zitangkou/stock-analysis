# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# 配置后热力图 API 读 PostgreSQL 真实行情（不配则仍用模拟数据）
# 本机连云库可用 SSH 隧道：ssh -L 5432:127.0.0.1:5432 root@你的云IP
DATABASE_URL=postgresql://stock:CHANGE_ME@127.0.0.1:5432/stock_market

