# PostgreSQL（云服务器）
DATABASE_URL=postgresql://stock:CHANGE_ME@127.0.0.1:5432/stock_market

# 股票池
UNIVERSE_SIZE=2000
# 权重：ROE / 净利润额 / 净利润同比 / 流动性（之和应为 1）
WEIGHT_ROE=0.35
WEIGHT_NET_PROFIT=0.25
WEIGHT_NET_PROFIT_YOY=0.25
WEIGHT_LIQUIDITY=0.15
# 上市满多少交易日才可入池
MIN_LIST_DAYS=120
# 近 20 日日均成交额下限（元），过滤流动性过差标的
MIN_AVG_AMOUNT_20D=20000000

# 盘中快照（偏保守，降低被封风险）
# 热力图 3 分钟刷新足够；稳定后再改回 60
QUOTE_INTERVAL_SEC=180
# 快照历史保留交易日数
SNAPSHOT_RETENTION_DAYS=40
# 新浪批量：每批股票数、批间休眠（秒）
QUOTE_BATCH_SIZE=100
QUOTE_BATCH_SLEEP=0.8

# 日线回填默认间隔（秒/只）；云主机建议 >= 2
BARS_SLEEP_SEC=2.0

# 时区
TZ=Asia/Shanghai
